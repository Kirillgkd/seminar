# Copy this file to .env and fill in your keys. Never commit the real .env.

# Anthropic (Claude) — preferred provider for AI interpretation
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-3-5-sonnet-20241022

# OpenAI-compatible alternative (used only if ANTHROPIC_API_KEY is empty)
OPENAI_API_KEY=
OPENAI_BASE_URL=https://api.openai.com/v1
OPENAI_MODEL=gpt-4o-mini
